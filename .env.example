PORT=8080
APP_URL=http://localhost:8080
VITE_APP_URL=http://localhost:8080

# App Identity
APP_NAME=FunnelX
APP_SLUG=funnelx

# Security
JWT_SECRET=your-super-secret-production-key-change-me

# PostgreSQL Configuration
# Reutilize o mesmo servidor/PostgreSQL e isole o FunnelX em um schema proprio.
DATABASE_URL="postgresql://postgres:password@localhost:5432/postgres"
DATABASE_SCHEMA="funnelx"
PRISMA_DATABASE_URL="postgresql://postgres:password@localhost:5432/postgres?schema=funnelx"

# Evolution API (WhatsApp) - mesma infraestrutura da Kogna
EVOLUTION_API_URL=https://evo.kogna.co
EVOLUTION_API_KEY=your-evolution-api-key-here
VITE_EVOLUTION_API_URL=https://tech.kogna.online
VITE_EVOLUTION_API_KEY=your-evolution-api-key-here
WEBHOOK_URL=http://localhost:8080/api/webhooks/whatsapp

# OpenAI Configuration
OPENAI_API_KEY=your-openai-api-key-here

# ElevenLabs (Voice/Audio)
ELEVENLABS_API_KEY=your-elevenlabs-api-key-here

# Mercado Pago (Payments)
MERCADOPAGO_ACCESS_TOKEN=your-mp-access-token-here
VITE_MERCADOPAGO_PUBLIC_KEY=your-mp-public-key-here
PAYMENT_WEBHOOK_SECRET=your-webhook-secret-here
MERCADOPAGO_CLIENT_ID=your-mp-client-id-here
MERCADOPAGO_CLIENT_SECRET=your-mp-client-secret-here

# Vite
VITE_API_URL=/api
